{
  "name": "dental-implant-identifier",
  "version": "1.0.0",
  "description": "Sistema de identificação de implantes dentários via radiografias — DII",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy": "bash deploy.sh",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 reload ecosystem.config.js --env production --update-env",
    "kill-port": "fuser -k 3001/tcp 2>/dev/null || lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "logs": "pm2 logs --lines 50",
    "status": "pm2 list"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
